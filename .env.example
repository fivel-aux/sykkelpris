# ── Database ──────────────────────────────────────────────────────────────────
# Pooled connection — used by the Next.js app at runtime (Supabase/Neon pooler URL).
DATABASE_URL="postgresql://user:password@localhost:5432/sykkelpris"

# Direct (non-pooled) connection — required by Prisma for migrations and the cron
# ingestion function. On Supabase: use the "Session mode" / direct connection URL.
# On Neon: append ?pgbouncer=false to the non-pooled URL.
DIRECT_URL="postgresql://user:password@localhost:5432/sykkelpris"

# ── Cron security ─────────────────────────────────────────────────────────────
# Any random string. Must match Authorization: Bearer <value> sent by Vercel Cron.
# For local testing: pass this as the Authorization header when calling /api/cron/ingest.
CRON_SECRET="change-me-to-any-random-string"

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
